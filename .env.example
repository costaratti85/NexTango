# Contrato de variables de entorno para dev local (Nextango)
# Copiar a .env y completar con los valores reales (que NO se commitean).
# Los valores se recuperan del servidor ERPNext (ver Orbit / Dispatch).

# --- ERPNext API (auth header: "Authorization: token <KEY>:<SECRET>") ---
# Site erp.local en :8000. Desde otra maquina: mapear erp.local en /etc/hosts
# o pegarle a la IP con header Host: erp.local.
ERPNEXT_BASE_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# --- Nexus / identificador de instancia ---
APP_INSTANCE_ID=

# --- Tango (LAN) ---
# server-t resuelve a la IP del Tango via /etc/hosts (ver setup de Orbit).
TANGO_URL=
TANGO_COMPANY=
