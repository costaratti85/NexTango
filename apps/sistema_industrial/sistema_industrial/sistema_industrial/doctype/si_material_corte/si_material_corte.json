{
  "doctype": "DocType",
  "name": "SI Material Corte",
  "module": "Sistema Industrial",
  "autoname": "format:{material} {espesor_mm}mm",
  "custom": 0,
  "editable_grid": 1,
  "is_submittable": 0,
  "istable": 0,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "material",
      "fieldtype": "Data",
      "label": "Material",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "familia",
      "fieldtype": "Select",
      "label": "Familia",
      "options": "\nhierro\ngalvanizada\ninox430\ninox304\nacero\notro",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "calibre",
      "fieldtype": "Data",
      "label": "Calibre",
      "default": "-",
      "in_list_view": 1
    },
    {
      "fieldname": "espesor_mm",
      "fieldtype": "Float",
      "label": "Espesor (mm)",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "densidad_kg_m2",
      "fieldtype": "Float",
      "label": "Densidad (kg/m²)",
      "reqd": 1
    },
    {
      "fieldname": "velocidad_corte_mm_s",
      "fieldtype": "Float",
      "label": "Velocidad de corte (mm/s)",
      "reqd": 1
    },
    {
      "fieldname": "tiempo_perforacion_s",
      "fieldtype": "Float",
      "label": "Tiempo perforación (s)",
      "default": "0.1"
    },
    {
      "fieldname": "consumible_por_perforacion",
      "fieldtype": "Float",
      "label": "Consumible/perforación",
      "default": "0"
    },
    {
      "fieldname": "sec_laser_calibrado",
      "fieldtype": "Section Break",
      "label": "Tiempo láser (fórmula calibrada)",
      "collapsible": 1,
      "description": "Constantes de regresión lineal: T = a·cut_mm + b·agujeros + c·área_m2 + d. Dejar en 0 para usar la fórmula legacy (velocidad + pierce)."
    },
    {
      "fieldname": "laser_a_s_per_mm",
      "fieldtype": "Float",
      "label": "a — coef. longitud (s/mm)",
      "default": "0",
      "precision": "6",
      "description": "Segundos por mm de recorrido de corte. Activa la fórmula calibrada si > 0."
    },
    {
      "fieldname": "laser_b_s_per_hole",
      "fieldtype": "Float",
      "label": "b — coef. agujeros (s/agujero)",
      "default": "0",
      "precision": "4",
      "description": "Overhead por figura cerrada (esquinas, aceleración)."
    },
    {
      "fieldname": "col_break_laser",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "laser_c_s_per_m2",
      "fieldtype": "Float",
      "label": "c — coef. área (s/m²)",
      "default": "0",
      "precision": "2",
      "description": "Overhead por m² de panel (viaje rápido entre zonas lejanas)."
    },
    {
      "fieldname": "laser_d_base_s",
      "fieldtype": "Float",
      "label": "d — overhead base (s)",
      "default": "0",
      "precision": "2",
      "description": "Overhead fijo por panel (inicialización de zonas, delays)."
    },
    {
      "fieldname": "sec_precios",
      "fieldtype": "Section Break",
      "label": "Precios"
    },
    {
      "fieldname": "precio_por_kg",
      "fieldtype": "Currency",
      "label": "Precio por kg (ARS)",
      "options": "ARS"
    },
    {
      "fieldname": "precio_plegar_por_kg",
      "fieldtype": "Currency",
      "label": "Precio plegar por kg (ARS)",
      "options": "ARS"
    },
    {
      "fieldname": "activo",
      "fieldtype": "Check",
      "label": "Activo",
      "default": "1",
      "in_list_view": 1,
      "in_standard_filter": 1
    }
  ],
  "permissions": [
    {
      "role": "SI Admin Produccion",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "SI Operador Panel",
      "read": 1
    },
    {
      "role": "SI Operador Plegado",
      "read": 1
    },
    {
      "role": "SI Operador Laser",
      "read": 1
    },
    {
      "role": "SI Vendedor",
      "read": 1
    },
    {
      "role": "SI Gerencia",
      "read": 1
    }
  ]
}
